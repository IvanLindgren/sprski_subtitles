GROQ_API_KEY=gsk_your_key_here
POLZA_AI_KEY=pza_your_key_here
POLZA_TRANSCRIPTION_MODEL=aiesa/transcribe
TRANSCRIPTION_PROVIDER=polza
POLZA_TRANSCRIPTION_TIMEOUT_MS=1800000
SUBTITLE_DELAY_SECONDS=0
YANDEX_TRANSLATE_API_KEY=your_yandex_translate_api_key
YANDEX_FOLDER_ID=your_yandex_cloud_folder_id
PORT=8787
MAX_ACTIVE_TRANSCRIPTIONS=1
MAX_ACTIVE_SHARED_TRANSCRIPTIONS=1
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=citavuk-public
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
PUBLIC_MEDIA_BASE_URL=https://pub-your-bucket.r2.dev
